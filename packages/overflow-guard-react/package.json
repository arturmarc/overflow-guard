{
  "name": "overflow-guard-react",
  "version": "0.0.1",
  "description": "React component and hook for content-aware responsive UI that adapts when content stops fitting, without breakpoints or magic numbers.",
  "license": "MIT",
  "author": "Artur Marczyk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arturmarc/overflow-guard.git",
    "directory": "packages/overflow-guard-react"
  },
  "homepage": "https://github.com/arturmarc/overflow-guard/tree/main/packages/overflow-guard-react#readme",
  "bugs": {
    "url": "https://github.com/arturmarc/overflow-guard/issues"
  },
  "keywords": [
    "react",
    "tanstack-intent",
    "overflow",
    "responsive",
    "content-aware",
    "content-aware-ui",
    "responsive-ui",
    "adaptive-ui",
    "layout",
    "toolbar",
    "navigation",
    "menu",
    "dynamic-content",
    "localization",
    "resize-observer",
    "render-props",
    "hook",
    "truncate"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "use-resize-observer": "^9.1.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "jsdom": "^28.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0-beta.13",
    "vitest": "^4.0.18"
  }
}
