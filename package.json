{
  "name": "overflow-guard",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run build:react && bun run build:website",
    "build:react": "cd packages/overflow-guard-react && bun run build",
    "build:website": "cd apps/website && bun run build",
    "dev": "cd apps/website && bun run dev",
    "test": "cd packages/overflow-guard-react && bun run test",
    "lint": "bunx eslint packages/overflow-guard-react apps/website",
    "typecheck": "bun run typecheck:react && bun run typecheck:website",
    "typecheck:react": "cd packages/overflow-guard-react && bun run typecheck",
    "typecheck:website": "cd apps/website && bun run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.48.0"
  }
}
